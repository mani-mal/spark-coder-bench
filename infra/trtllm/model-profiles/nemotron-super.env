# TensorRT-LLM serving profile — NVIDIA Nemotron-3-Super-120B-A12B-NVFP4
# The PRIMARY target of the TRT-LLM layer: this MIXED_PRECISION (FP8 Mamba + NVFP4 MoE)
# checkpoint is rejected by vLLM (see docs/findings/2026-06-25-nemotron-super-vllm-mixed-
# precision.md); TRT-LLM is NVIDIA's supported path on DGX Spark.
#
# Settings are NVIDIA's official single-Spark recipe (usage-cookbook/Nemotron-3-Super/
# SparkDeploymentGuide). REQUIRES container 1.3.0rc9 — 1.2.1 OOM-loads this checkpoint.
export MODEL_ID="nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4"
export SERVED_MODEL_NAME="nemotron-super"

# Official Spark recipe image (overrides serve script default).
export TRT_IMAGE="nvcr.io/nvidia/tensorrt-llm/release:1.3.0rc9"

export MAX_BATCH_SIZE="8"          # per the official guide
export TP_SIZE="1"
export EP_SIZE="1"                 # expert-parallel size (MoE)
export MAX_NUM_TOKENS="8192"       # caps prefill activation memory — key to fitting in 128GB
export MAX_SEQ_LEN="1048576"       # 1M; feasible because KV cache is FP8 (see config yaml)
export SEED="0"
export DECODE_TEMPERATURE="0.2"

# 1M max_seq_len needs this guard env. Forwarded by the serve script's TRT_ENV_PASSTHROUGH.
export TLLM_ALLOW_LONG_MAX_MODEL_LEN="1"

# Nemotron Super is a hybrid Mamba/attention + MoE reasoning model. Parsers per the Spark
# playbook recipe: nano-v3 reasoning, qwen3_coder tool calls (so OpenCode tool-use works).
export EXTRA_TRT_ARGS="--trust_remote_code \
  --reasoning_parser nano-v3 \
  --tool_parser qwen3_coder"
