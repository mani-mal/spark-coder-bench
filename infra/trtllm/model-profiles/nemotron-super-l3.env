# TensorRT-LLM serving profile — Nemotron-3-Super L3 (LiveCodeBench) variant, MTP DISABLED.
#
# Identical to nemotron-super.env except it selects configs/nemotron-super-l3.yaml (no
# speculative_config). SERVED_MODEL_NAME is deliberately kept as "nemotron-super" so the
# lcb_runner model entry, run-suite --profile, and RUN_ID all stay "nemotron-super" — the L3
# result is a nemotron-super result, just served without MTP. See the L3 yaml header and
# docs/findings/2026-07-01-nemotron-trt-mtp-wedge.md for why MTP is dropped for L3.
export MODEL_ID="nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4"
export SERVED_MODEL_NAME="nemotron-super"

export TRT_IMAGE="nvcr.io/nvidia/tensorrt-llm/release:1.3.0rc9"

export MAX_BATCH_SIZE="8"
export TP_SIZE="1"
export EP_SIZE="1"
export MAX_NUM_TOKENS="8192"
export MAX_SEQ_LEN="1048576"
export SEED="0"
export DECODE_TEMPERATURE="0.2"

export TLLM_ALLOW_LONG_MAX_MODEL_LEN="1"

export EXTRA_TRT_ARGS="--trust_remote_code \
  --reasoning_parser nano-v3 \
  --tool_parser qwen3_coder"
