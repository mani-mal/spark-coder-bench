# TensorRT-LLM serving profile — openai/gpt-oss-120b (MXFP4 MoE).
# Runtime BRIDGE: same model we ran on vLLM, re-run on TRT-LLM to isolate the runtime
# effect (perf) and confirm quality reproduces. gpt-oss-120B (MXFP4) is listed as
# Spark-supported in the playbook, but issue NVIDIA/TensorRT-LLM#8474 reports trouble
# — treat serving as empirical.
# MODEL_ID points at the LOCAL cached snapshot dir (not the repo id) so trtllm-serve loads
# weights + tokenizer straight from disk with NO network calls. Reason: the MXFP4 weight set
# (15 shards, ~63GB) is fully cached, but trtllm-serve's default repo download tries to also
# pull the bf16 `original/` set and HANGS on it; and HF_HUB_OFFLINE=1 makes the tokenizer loader
# fail on an HF API metadata call. A local path sidesteps both. Snapshot hash is the revision
# currently in cache; re-resolve via: ls ~/.cache/huggingface/hub/models--openai--gpt-oss-120b/snapshots/
export MODEL_ID="/root/.cache/huggingface/hub/models--openai--gpt-oss-120b/snapshots/b5c939de8f754692c1647ca79fbf85e8c1e70f8a"
export SERVED_MODEL_NAME="gpt-oss-120b"
export MAX_BATCH_SIZE="4"
export TP_SIZE="1"
export SEED="0"
export DECODE_TEMPERATURE="0.2"
# Start minimal (sanity = plain chat). Tool/reasoning parsers for gpt-oss harmony format
# are added when validating the tool-use gate if basic serving succeeds.
export EXTRA_TRT_ARGS="--trust_remote_code"
