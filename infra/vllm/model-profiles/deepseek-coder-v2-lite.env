# vLLM serving profile — DeepSeek-Coder-V2-Lite-Instruct (MoE: 64+2 experts, top-6)
# Third model: external sparse-activation anchor. bf16 (native; no NVFP4 checkpoint).
# Shares Qwen's serving params (both bf16, both fit at 0.80/65536) to minimize
# non-model confounds between the two bf16 models; Nemotron differs (NVFP4) — disclosed.
export MODEL_ID="deepseek-ai/DeepSeek-Coder-V2-Lite-Instruct"
export SERVED_MODEL_NAME="deepseek-coder-v2-lite"

export GPU_MEMORY_UTILIZATION="0.80"
export MAX_MODEL_LEN="65536"
export MAX_NUM_SEQS="1"
export MAX_NUM_BATCHED_TOKENS="16384"

# Equalized across models.
export SEED="0"
export DECODE_TEMPERATURE="0.2"
export KV_CACHE_DTYPE="auto"

# DeepSeek-V2 needs trust-remote-code. Tool parser: deepseek_v3 (closest in vLLM); if
# the installed image rejects it, drop the parser flags, confirm chat, then re-add.
export EXTRA_VLLM_ARGS="--dtype auto \
  --trust-remote-code \
  --seed ${SEED} \
  --enable-auto-tool-choice \
  --tool-call-parser deepseek_v3"
