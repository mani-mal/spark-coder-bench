# vLLM serving profile — Qwen3-Coder-30B-A3B-Instruct
# Pinned, version-controlled copy for reproducibility (the authoritative profile
# for the benchmark lives HERE, not in <vllm-serving-lab>).
export MODEL_ID="Qwen/Qwen3-Coder-30B-A3B-Instruct"
export SERVED_MODEL_NAME="qwen3-coder-30b"

# Memory-driven settings (cannot be fully equalized with Nemotron on 128GB unified
# memory; the manifest discloses the difference per the fairness controls).
export GPU_MEMORY_UTILIZATION="0.80"
export MAX_MODEL_LEN="65536"
export MAX_NUM_SEQS="1"            # pinned across models for clean per-task latency
export MAX_NUM_BATCHED_TOKENS="16384"

# Equalized across models where possible.
export SEED="0"
export DECODE_TEMPERATURE="0.2"    # logged; applied as a request param by the agent
export KV_CACHE_DTYPE="auto"

export EXTRA_VLLM_ARGS="--dtype auto \
  --trust-remote-code \
  --seed ${SEED} \
  --enable-auto-tool-choice \
  --tool-call-parser qwen3_coder"
