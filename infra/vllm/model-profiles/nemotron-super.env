# vLLM serving profile — NVIDIA Nemotron 3 Super 120B-A12B NVFP4
# Pinned, version-controlled copy for reproducibility.
export MODEL_ID="nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4"
export SERVED_MODEL_NAME="nemotron-super"

# Conservative memory-driven settings for the 120B NVFP4 MoE/hybrid model.
# These DIFFER from Qwen (larger weights) and the manifest discloses it.
export GPU_MEMORY_UTILIZATION="0.72"
export MAX_MODEL_LEN="32768"
export MAX_NUM_SEQS="1"            # pinned across models
export MAX_NUM_BATCHED_TOKENS="8192"

# Equalized across models where possible.
export SEED="0"
export DECODE_TEMPERATURE="0.2"    # logged; applied as a request param by the agent
export KV_CACHE_DTYPE="auto"

# Nemotron Super is MoE + hybrid Mamba/Transformer; keep trust-remote-code.
# If startup fails on a parser flag, drop --reasoning-parser first, confirm chat,
# then re-add (see project AI_USAGE.md).
export EXTRA_VLLM_ARGS="--dtype auto \
  --trust-remote-code \
  --seed ${SEED} \
  --enable-auto-tool-choice \
  --tool-call-parser qwen3_coder \
  --reasoning-parser nemotron_v3 \
  --mamba-ssm-cache-dtype float32"

# Blackwell/NVFP4 tuning (ignored if unsupported by the image).
export VLLM_FLASHINFER_MOE_BACKEND="latency"
export VLLM_USE_FLASHINFER_MOE_FP4="1"
export VLLM_USE_FLASHINFER_MOE_FP8="1"
