# vLLM serving profile — OpenAI gpt-oss-120b (MoE: 128 experts, top-4)
# Model #3 (replaces DeepSeek-V2-Lite): external agentic anchor + SECOND 4-bit MoE.
# Native MXFP4 weights (~63 GB) — Blackwell/SM121 has native FP4, so this pairs with
# Nemotron NVFP4 to separate "model effect" from "FP4-on-Blackwell effect". Apache-2.0.
export MODEL_ID="openai/gpt-oss-120b"
export SERVED_MODEL_NAME="gpt-oss-120b"

# MXFP4 weights are ~63 GB; 0.80 of 128 GB leaves ample room for weights + KV at 64K.
export GPU_MEMORY_UTILIZATION="0.80"
export MAX_MODEL_LEN="65536"
export MAX_NUM_SEQS="1"
export MAX_NUM_BATCHED_TOKENS="16384"

# Equalized across models.
export SEED="0"
export DECODE_TEMPERATURE="0.2"
export KV_CACHE_DTYPE="auto"

# gpt-oss uses the OpenAI "harmony" response format. In recent vLLM the MXFP4 quant is
# read from config (no explicit quant flag) and tool calls use the `openai` parser; the
# model also emits reasoning on a separate channel (reasoning-parser openai).
# If the installed image rejects a parser name, drop the parser flags, confirm basic
# chat + the sanity gate, then re-add the tool parser FIRST, reasoning parser second
# (same procedure as AI_USAGE.md "Parser flag fails"). The agentic-tool-use validation
# gate (direct tool_choice=auto + an OpenCode smoke) must pass before any timed run —
# this is the exact check DeepSeek-V2-Lite failed.
# Verified against vLLM 0.15.1 (nvcr 26.02): tool-call parser is "openai" (= the gpt-oss
# OpenAIToolParser); reasoning parser is "openai_gptoss" (NOT "openai" — that name only
# exists for tool parsing). MXFP4 loads via the Marlin weight-only kernel on SM121 (GB10
# has no native FP4 compute) — a disclosed performance caveat for the energy/throughput cuts.
export EXTRA_VLLM_ARGS="--dtype auto \
  --trust-remote-code \
  --seed ${SEED} \
  --enable-auto-tool-choice \
  --tool-call-parser openai \
  --reasoning-parser openai_gptoss"
