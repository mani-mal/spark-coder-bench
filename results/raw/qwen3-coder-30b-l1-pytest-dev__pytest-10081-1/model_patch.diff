new file mode 100644
index 0000000..0a0470c
--- /dev/null
+++ b/test_comprehensive.py
@@ -0,0 +1,19 @@
+import unittest
+
+# Test case with class-level skip
+@unittest.skip("class skipped")
+class SkippedTestCase(unittest.TestCase):
+    def setUp(self):
+        print("setUp called for skipped test")
+    def test_one(self):
+        pass
+    def tearDown(self):
+        print("tearDown called for skipped test")
+
+# Test case with method-level skip (should still work)
+class RegularTestCase(unittest.TestCase):
+    @unittest.skip("method skipped")
+    def test_two(self):
+        pass
+    def tearDown(self):
+        print("tearDown called for regular test")
