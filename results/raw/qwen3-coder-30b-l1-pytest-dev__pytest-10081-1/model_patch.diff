diff --git a/src/_pytest/unittest.py b/src/_pytest/unittest.py
index 851e494..c1f3dce 100644
--- a/src/_pytest/unittest.py
+++ b/src/_pytest/unittest.py
@@ -316,7 +316,11 @@ class TestCaseFunction(Function):
             # Arguably we could always postpone tearDown(), but this changes the moment where the
             # TestCase instance interacts with the results object, so better to only do it
             # when absolutely needed.
-            if self.config.getoption("usepdb") and not _is_skipped(self.obj):
+            # Check if either the test method or the class is skipped.
+            class_skipped = False
+            if self.parent is not None:
+                class_skipped = _is_skipped(self.parent.obj)
+            if self.config.getoption("usepdb") and not (_is_skipped(self.obj) or class_skipped):
                 self._explicit_tearDown = self._testcase.tearDown
                 setattr(self._testcase, "tearDown", lambda *args: None)
 
