+# Handle XDG Base Directory Specification compliance
+try:
+    import xdg.BaseDirectory
+    # Use XDG data directory for pylint data
+    PYLINT_HOME = xdg.BaseDirectory.save_data_path("pylint")
+except ImportError:
+    # Fallback to original behavior if xdg module is not available
+    USER_HOME = os.path.expanduser("~")
+    if "PYLINTHOME" in os.environ:
+        PYLINT_HOME = os.environ["PYLINTHOME"]
+        if USER_HOME == "~":
+            USER_HOME = os.path.dirname(PYLINT_HOME)
+    elif USER_HOME == "~":
+        PYLINT_HOME = ".pylint.d"
+    else:
+        PYLINT_HOME = os.path.join(USER_HOME, ".pylint.d")
 
 
