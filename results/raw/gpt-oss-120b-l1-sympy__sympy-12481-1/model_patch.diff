+# Import zeros; provide fallback if matrices module unavailable
+try:
+    from sympy.matrices import zeros
+except Exception:
+    def zeros(*args, **kwargs):
+        # Simple placeholder returning a list of lists of zeros
+        rows = args[0] if args else 0
+        cols = args[1] if len(args) > 1 else rows
+        return [[0]*cols for _ in range(rows)]
+# Import ifac for factorial; provide fallback if unavailable
+try:
+    from mpmath.libmp.libintmath import ifac
+except Exception:
+    def ifac(n):
+        # Simple factorial implementation
+        result = 1
+        for i in range(2, n+1):
+            result *= i
